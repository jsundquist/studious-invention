      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="configure-gitguardian_di" bpmnElement="configure-gitguardian">
        <dc:Bounds x="740" y="368" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="configure-sentry_di" bpmnElement="configure-sentry">
        <dc:Bounds x="740" y="490" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="configure-grafana-cloud_di" bpmnElement="configure-grafana-cloud">
        <dc:Bounds x="740" y="620" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="tools-join_di" bpmnElement="tools-join">
        <dc:Bounds x="900" y="383" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="provision-infrastructure_di" bpmnElement="provision-infrastructure">
        <dc:Bounds x="990" y="368" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="deploy-to-staging_di" bpmnElement="deploy-to-staging">
        <dc:Bounds x="1130" y="368" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="phase1-end_di" bpmnElement="phase1-end">
        <dc:Bounds x="1272" y="392" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="flow-p1-start-to-scaffold-repo_di" bpmnElement="flow-p1-start-to-scaffold-repo">
        <di:waypoint x="306" y="410" /><di:waypoint x="350" y="410" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow-scaffold-repo-to-scaffold-project_di" bpmnElement="flow-scaffold-repo-to-scaffold-project">
        <di:waypoint x="450" y="408" /><di:waypoint x="490" y="408" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow-scaffold-project-to-tools-fork_di" bpmnElement="flow-scaffold-project-to-tools-fork">
        <di:waypoint x="590" y="408" /><di:waypoint x="630" y="408" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow-fork-to-sonarcloud_di" bpmnElement="flow-fork-to-sonarcloud">
        <di:waypoint x="655" y="383" /><di:waypoint x="655" y="140" /><di:waypoint x="740" y="140" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow-fork-to-snyk_di" bpmnElement="flow-fork-to-snyk">
        <di:waypoint x="655" y="383" /><di:waypoint x="655" y="280" /><di:waypoint x="740" y="280" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow-fork-to-gitguardian_di" bpmnElement="flow-fork-to-gitguardian">
        <di:waypoint x="680" y="408" /><di:waypoint x="740" y="408" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow-fork-to-sentry_di" bpmnElement="flow-fork-to-sentry">
        <di:waypoint x="655" y="433" /><di:waypoint x="655" y="530" /><di:waypoint x="740" y="530" />
      </bpmndi:BPMNEdge>

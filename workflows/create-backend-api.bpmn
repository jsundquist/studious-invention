      <bpmndi:BPMNShape id="phase1-start_di" bpmnElement="phase1-start">
        <dc:Bounds x="270" y="392" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="scaffold-repository_di" bpmnElement="scaffold-repository">
        <dc:Bounds x="350" y="368" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="scaffold-project_di" bpmnElement="scaffold-project">
        <dc:Bounds x="490" y="368" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="tools-fork_di" bpmnElement="tools-fork">
        <dc:Bounds x="630" y="383" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="610" y="440" width="90" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="configure-sonarcloud_di" bpmnElement="configure-sonarcloud">
        <dc:Bounds x="740" y="100" width="100" height="80" />

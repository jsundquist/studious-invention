        <dc:Bounds x="3100" y="60" width="1100" height="700" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="phase-5-production_di" bpmnElement="phase-5-production" isExpanded="true">
        <dc:Bounds x="4250" y="200" width="500" height="420" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_di" bpmnElement="end">
        <dc:Bounds x="4812" y="392" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="4788" y="435" width="90" height="27" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Top-level sequence flows -->
      <bpmndi:BPMNEdge id="flow-start-to-phase1_di" bpmnElement="flow-start-to-phase1">
        <di:waypoint x="188" y="410" /><di:waypoint x="230" y="410" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow-phase1-to-phase2_di" bpmnElement="flow-phase1-to-phase2">
        <di:waypoint x="1330" y="410" /><di:waypoint x="1390" y="410" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow-phase2-to-phase3_di" bpmnElement="flow-phase2-to-phase3">
        <di:waypoint x="2090" y="410" /><di:waypoint x="2150" y="410" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow-phase3-to-phase4_di" bpmnElement="flow-phase3-to-phase4">
        <di:waypoint x="3050" y="410" /><di:waypoint x="3100" y="410" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow-phase4-to-phase5_di" bpmnElement="flow-phase4-to-phase5">

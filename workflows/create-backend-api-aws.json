              "Next": "Request Security Sign-off"
            },
            "Request Security Sign-off": {
              "Comment": "BPMN userTask 'request-security-signoff', after scans-join gateway.",
              "Type": "Task",
              "Resource": "arn:aws:states:::lambda:invoke",

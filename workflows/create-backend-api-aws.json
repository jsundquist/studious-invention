    "Phase 4: Resolve Security Findings": {
      "Comment": "Maps to BPMN subProcess 'phase-4-security-findings'. The nested Parallel mirrors the parallelGateway scans-fork/scans-join with four concurrent branches. Three branches loop via waitForTaskToken (BPMN intermediateCatchEvent). Security sign-off runs sequentially after the nested Parallel completes.",
      "Type": "Parallel",
      "Branches": [
        {
          "StartAt": "Security Scans",
          "States": {
            "Security Scans": {
              "Comment": "BPMN parallelGateway 'scans-fork/scans-join' — four concurrent branches.",
              "Type": "Parallel",
              "Branches": [
                {
                  "Comment": "BPMN: check-sonarcloud-threshold → sonarcloud-threshold-gateway → clear: scans-join | breached: sonarcloud-threshold-catch (intermediateCatchEvent) → recheck loop",
                  "StartAt": "Check SonarCloud Threshold",
                  "States": {
                    "Check SonarCloud Threshold": {
                      "Type": "Task",
                      "Resource": "arn:aws:states:::lambda:invoke",
                      "Output": "{% $states.result.Payload %}",
                      "Arguments": { "Payload": "{% $states.input %}" },
                      "Retry": [{ "ErrorEquals": ["Lambda.ServiceException", "Lambda.AWSLambdaException", "Lambda.SdkClientException", "Lambda.TooManyRequestsException"], "IntervalSeconds": 1, "MaxAttempts": 3, "BackoffRate": 2, "JitterStrategy": "FULL" }],
                      "Next": "SonarCloud Threshold Gateway"
                    },
                    "SonarCloud Threshold Gateway": {
                      "Type": "Choice",
                      "Choices": [
                        { "Condition": "{% $states.input.sonarcloudThresholdClear = true %}", "Next": "SonarCloud Clear" }
                      ],
                      "Default": "Await SonarCloud Cleared"
                    },
                    "Await SonarCloud Cleared": {
                      "Comment": "BPMN intermediateCatchEvent 'sonarcloud-threshold-catch'. Pauses until an external callback sends the task token back.",
                      "Type": "Task",
                      "Resource": "arn:aws:states:::lambda:invoke.waitForTaskToken",
                      "Arguments": {
                        "Payload": {
                          "taskToken": "{% $states.context.Task.Token %}",
                          "serviceId": "{% $states.input.serviceId %}"
                        }
                      },
                      "Next": "Check SonarCloud Threshold"
                    },
                    "SonarCloud Clear": { "Type": "Pass", "End": true }
                  }
                },
                {
                  "Comment": "BPMN: check-snyk-threshold → snyk-threshold-gateway → clear: scans-join | breached: snyk-threshold-catch → recheck loop",
                  "StartAt": "Check Snyk Threshold",
                  "States": {
                    "Check Snyk Threshold": {
                      "Type": "Task",
                      "Resource": "arn:aws:states:::lambda:invoke",
                      "Output": "{% $states.result.Payload %}",
                      "Arguments": { "Payload": "{% $states.input %}" },
                      "Retry": [{ "ErrorEquals": ["Lambda.ServiceException", "Lambda.AWSLambdaException", "Lambda.SdkClientException", "Lambda.TooManyRequestsException"], "IntervalSeconds": 1, "MaxAttempts": 3, "BackoffRate": 2, "JitterStrategy": "FULL" }],
                      "Next": "Snyk Threshold Gateway"
                    },
                    "Snyk Threshold Gateway": {
                      "Type": "Choice",
                      "Choices": [
                        { "Condition": "{% $states.input.snykThresholdClear = true %}", "Next": "Snyk Clear" }
                      ],
                      "Default": "Await Snyk Cleared"
                    },
                    "Await Snyk Cleared": {
                      "Comment": "BPMN intermediateCatchEvent 'snyk-threshold-catch'.",
                      "Type": "Task",
                      "Resource": "arn:aws:states:::lambda:invoke.waitForTaskToken",
                      "Arguments": {
                        "Payload": {
                          "taskToken": "{% $states.context.Task.Token %}",
                          "serviceId": "{% $states.input.serviceId %}"
                        }
                      },
                      "Next": "Check Snyk Threshold"
                    },
                    "Snyk Clear": { "Type": "Pass", "End": true }
                  }
                },
                {
                  "Comment": "BPMN: check-gitguardian-threshold → gitguardian-threshold-gateway → clear: scans-join | breached: gitguardian-threshold-catch → recheck loop",
                  "StartAt": "Check GitGuardian Threshold",
                  "States": {
                    "Check GitGuardian Threshold": {
                      "Type": "Task",
                      "Resource": "arn:aws:states:::lambda:invoke",
                      "Output": "{% $states.result.Payload %}",
                      "Arguments": { "Payload": "{% $states.input %}" },
                      "Retry": [{ "ErrorEquals": ["Lambda.ServiceException", "Lambda.AWSLambdaException", "Lambda.SdkClientException", "Lambda.TooManyRequestsException"], "IntervalSeconds": 1, "MaxAttempts": 3, "BackoffRate": 2, "JitterStrategy": "FULL" }],
                      "Next": "GitGuardian Threshold Gateway"
                    },
                    "GitGuardian Threshold Gateway": {
                      "Type": "Choice",
                      "Choices": [
                        { "Condition": "{% $states.input.gitguardianThresholdClear = true %}", "Next": "GitGuardian Clear" }
                      ],
                      "Default": "Await GitGuardian Cleared"
                    },
                    "Await GitGuardian Cleared": {
                      "Comment": "BPMN intermediateCatchEvent 'gitguardian-threshold-catch'.",
                      "Type": "Task",
                      "Resource": "arn:aws:states:::lambda:invoke.waitForTaskToken",
                      "Arguments": {
                        "Payload": {
                          "taskToken": "{% $states.context.Task.Token %}",
                          "serviceId": "{% $states.input.serviceId %}"
                        }
                      },
                      "Next": "Check GitGuardian Threshold"
                    },
                    "GitGuardian Clear": { "Type": "Pass", "End": true }
